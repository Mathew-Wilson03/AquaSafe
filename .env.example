# ============================================================
# AquaSafe - Railway Environment Variables Template
# Copy these variable names into Railway Dashboard >
#   Project → Variables → Add Variable
# ============================================================

# --- Database (Azure MySQL) ---
DB_HOST=aquasafe-db.mysql.database.azure.com
DB_USERNAME=aquasafeadmin
DB_PASSWORD=your_password_here
DB_NAME=aquasafe

# --- Firebase Admin SDK ---
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=aquasafe-iot-project-5f966
FIREBASE_PRIVATE_KEY_ID=your_key_id_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@aquasafe-iot-project-5f966.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-fbsvc%40aquasafe-iot-project-5f966.iam.gserviceaccount.com
FIREBASE_UNIVERSE_DOMAIN=googleapis.com
